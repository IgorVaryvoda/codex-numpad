#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME="$ROOT/.runtime/whisper.cpp"
REF="${WHISPER_CPP_REF:-v1.8.1}"
MODEL="${KBD_DICTATE_MODEL:-base.en}"
MODEL_FILE="$RUNTIME/models/ggml-$MODEL.bin"

for command in git cmake curl; do
    command -v "$command" >/dev/null 2>&1 || {
        printf 'Missing required command: %s\n' "$command" >&2
        exit 1
    }
done

if [[ ! -d "$RUNTIME/.git" ]]; then
    mkdir -p "$(dirname "$RUNTIME")"
    git clone --depth 1 --branch "$REF" https://github.com/ggerganov/whisper.cpp.git "$RUNTIME"
fi

# $ORIGIN-relative runpaths keep the uninstalled build working if the repo moves.
CMAKE_COMMON=(-DCMAKE_BUILD_TYPE=Release -DCMAKE_BUILD_RPATH_USE_ORIGIN=ON)

if [[ ! -x "$RUNTIME/build/bin/whisper-cli" ]]; then
    if command -v nvcc >/dev/null 2>&1; then
        if ! cmake -S "$RUNTIME" -B "$RUNTIME/build" \
            "${CMAKE_COMMON[@]}" \
            -DGGML_CUDA=ON; then
            rm -rf "$RUNTIME/build"
            cmake -S "$RUNTIME" -B "$RUNTIME/build" "${CMAKE_COMMON[@]}"
        fi
    else
        cmake -S "$RUNTIME" -B "$RUNTIME/build" "${CMAKE_COMMON[@]}"
    fi
    cmake --build "$RUNTIME/build" --config Release -j "$(nproc)"
fi

if [[ ! -f "$MODEL_FILE" ]]; then
    "$RUNTIME/models/download-ggml-model.sh" "$MODEL"
fi

printf 'Dictation runtime ready:\n  %s\n  %s\n' \
    "$RUNTIME/build/bin/whisper-cli" "$MODEL_FILE"
